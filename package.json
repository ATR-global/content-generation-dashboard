{
  "name": "starter-project",
  "description": "Starter scaffold based on sparked-ui directory conventions",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.dev.mts",
    "build": "vite build --config vite.config.prod.mts",
    "preview": "vite preview --config vite.config.prod.mts",
    "type-check": "vue-tsc --build --force",
    "build:widget": "vite build --config vite.widget.config.ts",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@primevue/themes": "^4.5.4",
    "chart.js": "^4.5.1",
    "pinia": "^2.1.7",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "tippy.js": "^6.3.7",
    "vue": "^3.4.29",
    "vue-router": "^4.4.5",
    "vue-tippy": "^6.7.1"
  },
  "devDependencies": {
    "@tsconfig/node20": "^20.1.4",
    "@types/node": "^20.14.5",
    "@vitejs/plugin-vue": "^5.0.5",
    "@vue/tsconfig": "^0.5.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "sass-embedded": "^1.99.0",
    "tailwindcss": "^3.4.14",
    "typescript": "~5.4.0",
    "vite": "^5.3.1",
    "vite-plugin-wasm": "^3.5.0",
    "vue-tsc": "^2.0.21"
  }
}
